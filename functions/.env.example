# RentalHub system Google Drive workspace settings
# Copy these values to Firebase Functions environment/secrets; do not commit real secrets.

DRIVE_WORKSPACE_ROOT=taipeimetrohouse
SYSTEM_OWNER_EMAIL=metroclaw168@gmail.com

# Option A: personal Gmail / one-time admin OAuth refresh token
SYSTEM_DRIVE_CLIENT_ID=
SYSTEM_DRIVE_CLIENT_SECRET=
SYSTEM_DRIVE_REFRESH_TOKEN=

# Option B: service account / Shared Drive / Workspace domain delegation
SYSTEM_DRIVE_CLIENT_EMAIL=
SYSTEM_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
SYSTEM_DRIVE_IMPERSONATE_EMAIL=

# If true, uploaded files become anyone-with-link readable for direct image/PDF preview.
# If false, files remain private and the app should use a future preview proxy for inline preview.
DRIVE_PUBLIC_READ=false
